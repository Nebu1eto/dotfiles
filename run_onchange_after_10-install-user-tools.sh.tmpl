#!/usr/bin/env bash
set -euo pipefail

{{- if eq .chezmoi.os "darwin" }}
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi
{{- end }}

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

if ! command -v rustup >/dev/null 2>&1; then
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
fi

if [ ! -d "$HOME/.nvm" ]; then
  curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash
fi

if ! command -v poetry >/dev/null 2>&1; then
  if command -v uv >/dev/null 2>&1; then
    uv tool install poetry
  else
    poetry_python="$(command -v python3.11 || command -v python3)"
    curl -sSL https://install.python-poetry.org | "$poetry_python" -
  fi
fi

zjstatus_version="v0.23.0"
zjstatus_dir="$HOME/.config/zellij/plugins"
zjstatus_wasm="$zjstatus_dir/zjstatus.wasm"
zjstatus_url="https://github.com/dj95/zjstatus/releases/download/$zjstatus_version/zjstatus.wasm"

mkdir -p "$zjstatus_dir"
if [ ! -s "$zjstatus_wasm" ]; then
  tmp_wasm="$(mktemp)"
  curl -fsSL "$zjstatus_url" -o "$tmp_wasm"
  install -m 0644 "$tmp_wasm" "$zjstatus_wasm"
  rm -f "$tmp_wasm"
fi

{{- if eq .chezmoi.os "linux" }}
if ! command -v starship >/dev/null 2>&1; then
  curl -fsSL https://starship.rs/install.sh | sh -s -- --yes
fi

if ! command -v zellij >/dev/null 2>&1 && [ -x "$HOME/.cargo/bin/cargo" ]; then
  "$HOME/.cargo/bin/cargo" install zellij --locked
fi
{{- end }}
