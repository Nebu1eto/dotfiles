#!/usr/bin/env bash
set -euo pipefail

{{- if eq .chezmoi.os "darwin" }}
# Brewfile checksum: {{ include "Brewfile" | sha256sum }}
if [ "${DOTFILES_SKIP_BREW_BUNDLE:-}" = "1" ]; then
  echo "Skipping brew bundle because DOTFILES_SKIP_BREW_BUNDLE=1"
  exit 0
fi

if ! command -v brew >/dev/null 2>&1; then
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

brew bundle --file "{{ .chezmoi.sourceDir }}/Brewfile" --no-upgrade --jobs 1
{{- else if eq .chezmoi.os "linux" }}
if command -v apt-get >/dev/null 2>&1; then
  sudo apt-get update
  sudo apt-get install -y \
    build-essential \
    curl \
    git \
    git-lfs \
    htop \
    mysql-client \
    postgresql-client \
    python3 \
    python3-pip \
    tree \
    unzip \
    wget \
    zip \
    zsh
  sudo apt-get install -y bat || true
  sudo apt-get install -y lsd || true
  sudo apt-get install -y neovim || true
elif command -v dnf >/dev/null 2>&1; then
  sudo dnf install -y \
    bat \
    curl \
    gcc \
    gcc-c++ \
    git \
    git-lfs \
    htop \
    lsd \
    make \
    neovim \
    python3 \
    python3-pip \
    tree \
    unzip \
    wget \
    zip \
    zsh
elif command -v pacman >/dev/null 2>&1; then
  sudo pacman -Syu --needed --noconfirm \
    base-devel \
    bat \
    curl \
    git \
    git-lfs \
    htop \
    lsd \
    neovim \
    python \
    python-pip \
    tree \
    unzip \
    wget \
    zip \
    zsh
else
  echo "No supported Linux package manager found. Install packages manually, then rerun chezmoi apply." >&2
fi
{{- end }}
